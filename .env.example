# 复制为 .env.local 并填入真实值（.env.local 已 gitignore）。
# 阿里云 OSS 图床凭据（用于把参考图转成公网 URL 给中转站）。
MAIN_VITE_OSS_KEY_ID=
MAIN_VITE_OSS_KEY_SECRET=
MAIN_VITE_OSS_BUCKET=your-bucket
MAIN_VITE_OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
MAIN_VITE_OSS_CDN=https://your-bucket.oss-cn-beijing.aliyuncs.com
MAIN_VITE_OSS_PREFIX=tuchuang
